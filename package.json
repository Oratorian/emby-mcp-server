{
  "name": "@mahesvara/emby-mcp-server",
  "version": "1.2.0",
  "description": "MCP server for Emby: library search, scheduled tasks, and session control. Slim JSON responses tuned for small local models.",
  "license": "GPL-3.0-or-later",
  "author": "Oratorian",
  "homepage": "https://github.com/Oratorian/emby-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/Oratorian/emby-mcp-server/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Oratorian/emby-mcp-server.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "emby-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
